#!/bin/sh
# watchdog test/repair da conectividade de internet publica.
# Pede reboot da placa apos REBOOT_AFTER segundos de falha continua.
set -u

TRACK="internet"
TARGETS="8.8.8.8 1.1.1.1"   # sucesso se QUALQUER um responder
REBOOT_AFTER=180            # 3 minutos
REPAIR_EVERY=60             # re-tenta remediacao no maximo a cada 60s

probe() {
    for t in $TARGETS; do
        if ping -c 1 -W 2 "$t" >/dev/null 2>&1; then
            return 0
        fi
    done
    return 1
}

remediate() {
    # Fire-and-forget: nmcli reconnect can block up to its timeout, and the
    # watchdog daemon does NOT feed /dev/watchdog while this script runs.
    # Background the whole thing and redirect ALL fds off the inherited
    # stdout/stderr so the parent returns immediately (and never holds a pipe).
    ( timeout 8 nmcli -w 8 device reconnect wlan0 \
      || systemctl restart --no-block NetworkManager ) </dev/null >/dev/null 2>&1 &
    return 0
}

. "${WATCHDOG_LIB:-/usr/local/lib/watchdog-connectivity.sh}"
run_watchdog_check "${1:-test}"
